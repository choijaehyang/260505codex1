{
  "name": "ima2-gen",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "forwardPorts": [3333],
  "portsAttributes": {
    "3333": {
      "label": "ima2-gen",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "npm ci && npm --prefix ui ci && npm run build:server && npm run build:cli && npm --prefix ui run build",
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint"],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
